<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Responsive Image Gallery</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <header class="gallery-header">
    <h1>Visual Inspirations</h1>
    <p>A responsive image grid layout optimized for desktops, tablets, and smartphones.</p>
  </header>

  <main class="gallery-container">
    <!-- Image Item 1 -->
    <div class="gallery-item">
      <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=600&q=80" alt="Mountain landscape with a lake reflecting trees">
      <div class="overlay">
        <span>Alpine Serenity</span>
      </div>
    </div>

    <!-- Image Item 2 -->
    <div class="gallery-item">
      <img src="https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&w=600&q=80" alt="Foggy forest path during sunrise">
      <div class="overlay">
        <span>Misty Woodlands</span>
      </div>
    </div>

    <!-- Image Item 3 -->
    <div class="gallery-item">
      <img src="https://images.unsplash.com/photo-1447752875215-b2761acb3c5d?auto=format&fit=crop&w=600&q=80" alt="Wooden footbridge winding through lush green forest">
      <div class="overlay">
        <span>Forest Pathway</span>
      </div>
    </div>

    <!-- Image Item 4 -->
    <div class="gallery-item">
      <img src="https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=600&q=80" alt="Person standing on a cliff edge looking at epic valley views">
      <div class="overlay">
        <span>Horizon Vista</span>
      </div>
    </div>

    <!-- Image Item 5 -->
    <div class="gallery-item">
      <img src="https://images.unsplash.com/photo-1501854140801-50d01698950b?auto=format&fit=crop&w=600&q=80" alt="Green rolling hills stretching out under clouds">
      <div class="overlay">
        <span>Emerald Valley</span>
      </div>
    </div>

    <!-- Image Item 6 -->
    <div class="gallery-item">
      <img src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=600&q=80" alt="Sunlight streaming directly through tall redwood trees">
      <div class="overlay">
        <span>Golden Canopy</span>
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 Responsive Grid Gallery Concept.</p>
  </footer>

</body>
</html>
